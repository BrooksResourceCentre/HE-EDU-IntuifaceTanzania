{
  "kind": "discovery#restDescription",
  "discoveryVersion": "v1",
  "id": "countdownjs:v1",
  "name": "CountdownJS",
  "version": "v1.4",
  "title": "Countdown",
  "if.category": "Time",
  "protocol": "js",
  "basePath": "Countdown",
  "if.dependencies": [
    "EventEmitter.js",
    "Countdown.js"
  ],
  "icons": {
    "x32": "icon_countdown_32.png"
  },
  "schemas": {
    "Countdown": {
      "id": "Countdown",
      "type": "object",
      "description": "Countdown",
      "properties": {
        "seconds": {
          "title": "Seconds",
          "type": "integer",
          "description": "Current second",
          "default": 10
        },
        "minutes": {
          "title": "Minutes",
          "type": "integer",
          "description": "Current minute",
          "default": 0
        },
        "hours": {
          "title": "Hours",
          "type": "integer",
          "description": "Current hour",
          "default": 0
        },
        "days": {
          "title": "Days",
          "type": "integer",
          "description": "Current day",
          "default": 0
        },
        "formattedSeconds": {
          "title": "Formatted seconds",
          "type": "string",
          "description": "Current second, formatted with 2 digits",
          "readonly": true,
          "default": "10"
        },
        "formattedMinutes": {
          "title": "Formatted minutes",
          "type": "string",
          "description": "Current minute, formatted with 2 digits",
          "readonly": true,
          "default": "00"
        },
        "formattedHours": {
          "type": "string",
          "title": "Formatted hours",
          "description": "Current hour, formatted with 2 digits",
          "readonly": true,
          "default": "00"
        },
        "time": {
          "title": "Time",
          "type": "string",
          "description": "Current formatted time",
          "readonly": true,
          "default": "00:00:10"
        },
        "totalDays": {
          "title": "Remaining duration in days",
          "type": "number",
          "description": "Remaining total days",
          "readonly": true,
          "default": "0"
        },
        "totalHours": {
          "title": "Remaining duration in hours",
          "type": "number",
          "description": "Remaining total hours",
          "readonly": true,
          "default": "0"
        },
        "totalMinutes": {
          "title": "Remaining duration in minutes",
          "type": "number",
          "description": "Remaining total minutes",
          "readonly": true,
          "default": "0"
        },
        "totalSeconds": {
          "title": "Remaining duration in seconds",
          "type": "number",
          "description": "Remaining total seconds",
          "readonly": true,
          "default": "0"
        }
      }
    }
  },
  "resources": {
    "Countdown": {
      "id": "Countdown",
      "if.interfaceAsset": "true",
      "templateDesignAccelerator": "Countdown.dax",
      "title": "Countdown",
      "description": "Operations of countdown",
      "methods": {
        "start": {
          "id": "Countdown.start",
          "path": "start",
          "title": "Start",
          "description": "Start the countdown",
          "response": {
            "type": "none"
          }
        },
        "pause": {
          "id": "Countdown.pause",
          "path": "pause",
          "title": "Pause",
          "description": "Pause the countdown",
          "response": {
            "type": "none"
          }
        },
        "reset": {
          "id": "Countdown.reset",
          "path": "reset",
          "title": "Reset",
          "description": "Reset the countdown",
          "response": {
            "type": "none"
          }
        }
      },
      "events": {
        "timeChanged": {
          "id": "timeChanged",
          "title": "Time changed",
          "properties": {
            "hours": {
              "description": "The new hours value",
              "type": "integer"
            },
            "minutes": {
              "description": "The new minutes value",
              "type": "integer"
            },
            "seconds": {
              "description": "The new seconds value",
              "type": "integer"
            }
          }
        },
        "formattedSecondsChanged": {
          "id": "FormattetdSecondsChanged",
          "if.category": "Countdown",
          "title": "Formatted seconds changed"
        },
        "formattedMinutesChanged": {
          "id": "FormattedMinutesChanged",
          "if.category": "Countdown",
          "title": "Formatted minutes changed"
        },
        "formattedHoursChanged": {
          "id": "FormattedHoursChanged",
          "if.category": "Countdown",
          "title": "Formatted hours changed"
        },
        "secondsChanged": {
          "id": "SecondsChanged",
          "if.category": "Countdown",
          "title": "Seconds changed"
        },
        "minutesChanged": {
          "id": "MinutesChanged",
          "if.category": "Countdown",
          "title": "Minutes changed"
        },
        "hoursChanged": {
          "id": "HoursChanged",
          "if.category": "Countdown",
          "title": "Hours changed"
        },
        "daysChanged": {
          "id": "DaysChanged",
          "if.category": "Countdown",
          "title": "Days changed"
        },
        "started": {
          "id": "CountdownStarted",
          "if.category": "Countdown",
          "title": "Countdown started"
        },
        "paused": {
          "id": "CountdownPaused",
          "if.category": "Countdown",
          "title": "Countdown paused"
        }
      }
    }
  },
  "signature": {
    "hash": "dJGg/XX/SHkrt9QgPl95tNSUYUOhmZUnP8mD0JrABQs=",
    "signatureData": {
      "editionLevel": "FREE",
      "hostname": "SAPIN5",
      "isTrial": false,
      "v": 2,
      "data": "",
      "key": "",
      "iv": ""
    }
  }
}